{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    // ADICIONE OU ALTERE ESTAS DUAS LINHAS ABAIXO:
    "moduleResolution": "bundler",
    "customConditions": ["react-native"] 
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}